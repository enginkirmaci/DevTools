<UserControl
	x:Class="Tools.SnapIt.Controls.SnapOverlay"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:Tools.SnapIt.Controls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	HorizontalAlignment="Left"
	VerticalAlignment="Top"
	d:DesignHeight="300"
	d:DesignWidth="300"
	mc:Ignorable="d">

	<Grid
		x:Name="Overlay"
		Background="{Binding Theme.OverlayBrush, FallbackValue=#FF636363}"
		Opacity="{Binding Theme.Opacity, FallbackValue=0.85}">
		<Border
			x:Name="Border"
			BorderBrush="{Binding Theme.BorderBrush, FallbackValue=#FFC8C8C8}"
			BorderThickness="{Binding Theme.BorderThickness, FallbackValue=1}" />

		<Grid
			x:Name="MergedIcon"
			Width="64"
			Height="64"
			HorizontalAlignment="Center"
			VerticalAlignment="Center">
			<TextBlock
				x:Name="icon1"
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				FontFamily="Segoe MDL2 Assets"
				FontSize="64"
				Foreground="{Binding Theme.BorderBrush, FallbackValue=#FFC8C8C8}"
				Text="{x:Static controls:IconGlyph.ResizeLarge24}" />
			<TextBlock
				x:Name="icon2"
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				FontFamily="Segoe MDL2 Assets"
				FontSize="64"
				Foreground="{Binding Theme.BorderBrush, FallbackValue=#FFC8C8C8}"
				RenderTransformOrigin="0.5,0.5"
				Text="{x:Static controls:IconGlyph.ResizeLarge24}">
				<TextBlock.LayoutTransform>
					<TransformGroup>
						<ScaleTransform ScaleX="-1" />
						<SkewTransform />
						<RotateTransform />
						<TranslateTransform />
					</TransformGroup>
				</TextBlock.LayoutTransform>
			</TextBlock>
		</Grid>
	</Grid>
</UserControl>