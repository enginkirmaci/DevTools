<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        ================================================================
        THEME RESOURCES
        All semantic colors are defined here and bound to ThemeVariants
        so that the entire UI responds automatically to the
        application theme (Light/Dark) without any code-behind.

        Design language: "Refined Dark" — a modern, layered IDE aesthetic
        (Linear/Vercel style) with elevated surfaces, hairline borders and a
        cohesive indigo accent.
        ================================================================
    -->
    <ResourceDictionary.ThemeDictionaries>

        <ResourceDictionary x:Key="Dark">
            <!-- Surfaces (stepped neutrals for depth) -->
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0D0D0F" />
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#111114" />
            <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#0D0D0F" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#17171B" />
            <SolidColorBrush x:Key="CardSubtleBackgroundBrush" Color="#1F1F24" />
            <SolidColorBrush x:Key="DividerBrush" Color="#262629" />
            <SolidColorBrush x:Key="HairlineBrush" Color="#2A2A2E" />
            <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="#1A2540" />
            <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#1E1E23" />

            <!-- Text -->
            <SolidColorBrush x:Key="TitleForegroundBrush" Color="#F4F4F5" />
            <SolidColorBrush x:Key="SubtitleForegroundBrush" Color="#D4D4D8" />
            <SolidColorBrush x:Key="BodyForegroundBrush" Color="#D4D4D8" />
            <SolidColorBrush x:Key="MutedForegroundBrush" Color="#8B8B92" />
            <SolidColorBrush x:Key="FaintForegroundBrush" Color="#5C5C63" />

            <!-- Accent (indigo/blue family) -->
            <SolidColorBrush x:Key="AccentPrimaryBrush" Color="#3B82F6" />
            <SolidColorBrush x:Key="AccentPrimaryHoverBrush" Color="#2563EB" />
            <SolidColorBrush x:Key="AccentPrimaryPressedBrush" Color="#1D4ED8" />
            <SolidColorBrush x:Key="AccentSoftBrush" Color="#1A2540" />
            <SolidColorBrush x:Key="AccentSoftBorderBrush" Color="#1E3A5F" />
            <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF" />

            <!-- Status indicators -->
            <SolidColorBrush x:Key="StatusActiveBrush" Color="#22C55E" />
            <SolidColorBrush x:Key="StatusInactiveBrush" Color="#9E9E9E" />
            <SolidColorBrush x:Key="InfoAccentBrush" Color="#3B82F6" />
            <SolidColorBrush x:Key="WarningAccentBrush" Color="#F59E0B" />
            <SolidColorBrush x:Key="DangerAccentBrush" Color="#EF4444" />
            <SolidColorBrush x:Key="PurpleAccentBrush" Color="#8B5CF6" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
            <!-- Surfaces -->
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F6F7F9" />
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#F6F7F9" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="CardSubtleBackgroundBrush" Color="#F1F2F4" />
            <SolidColorBrush x:Key="DividerBrush" Color="#E5E7EB" />
            <SolidColorBrush x:Key="HairlineBrush" Color="#E5E7EB" />
            <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="#EFF4FF" />
            <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#F1F2F4" />

            <!-- Text -->
            <SolidColorBrush x:Key="TitleForegroundBrush" Color="#18181B" />
            <SolidColorBrush x:Key="SubtitleForegroundBrush" Color="#3F3F46" />
            <SolidColorBrush x:Key="BodyForegroundBrush" Color="#3F3F46" />
            <SolidColorBrush x:Key="MutedForegroundBrush" Color="#71717A" />
            <SolidColorBrush x:Key="FaintForegroundBrush" Color="#A1A1AA" />

            <!-- Accent (indigo/blue family) -->
            <SolidColorBrush x:Key="AccentPrimaryBrush" Color="#2563EB" />
            <SolidColorBrush x:Key="AccentPrimaryHoverBrush" Color="#1D4ED8" />
            <SolidColorBrush x:Key="AccentPrimaryPressedBrush" Color="#1E40AF" />
            <SolidColorBrush x:Key="AccentSoftBrush" Color="#EFF4FF" />
            <SolidColorBrush x:Key="AccentSoftBorderBrush" Color="#DBE6FF" />
            <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF" />

            <!-- Status indicators -->
            <SolidColorBrush x:Key="StatusActiveBrush" Color="#16A34A" />
            <SolidColorBrush x:Key="StatusInactiveBrush" Color="#757575" />
            <SolidColorBrush x:Key="InfoAccentBrush" Color="#2563EB" />
            <SolidColorBrush x:Key="WarningAccentBrush" Color="#D97706" />
            <SolidColorBrush x:Key="DangerAccentBrush" Color="#DC2626" />
            <SolidColorBrush x:Key="PurpleAccentBrush" Color="#7C3AED" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!--
        ================================================================
        DESIGN TOKENS
        Centralized numeric tokens for spacing, sizing and radius.
        ================================================================
    -->
    <x:Double x:Key="SpacingXs">4</x:Double>
    <x:Double x:Key="SpacingSm">8</x:Double>
    <x:Double x:Key="SpacingMd">12</x:Double>
    <x:Double x:Key="SpacingLg">16</x:Double>
    <x:Double x:Key="SpacingXl">24</x:Double>

    <CornerRadius x:Key="CardRadius">10</CornerRadius>
    <CornerRadius x:Key="ControlRadius">8</CornerRadius>
    <CornerRadius x:Key="PillRadius">14</CornerRadius>
    <CornerRadius x:Key="ChipRadius">6</CornerRadius>

    <!--
        ================================================================
        ELEVATION SHADOWS
        BoxShadows used by cards and elevated surfaces. Defined as
        plain resources (not theme-bound) so they resolve via
        DynamicResource from the control styles.
        ================================================================
    -->
    <BoxShadows x:Key="CardShadow">0 1 2 0 #14000000</BoxShadows>
    <BoxShadows x:Key="CardHoverShadow">0 8 24 0 #24000000</BoxShadows>
    <BoxShadows x:Key="FlyoutShadow">0 12 32 0 #33000000</BoxShadows>

</ResourceDictionary>
