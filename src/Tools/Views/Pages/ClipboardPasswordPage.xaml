<UserControl
        x:Class="Tools.Views.Pages.ClipboardPasswordPage"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Tools.Library.Converters;assembly=Tools.Library"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DesignHeight="400"
        d:DesignWidth="600"
        mc:Ignorable="d">

        <UserControl.Resources>
                <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        </UserControl.Resources>

        <ScrollViewer>
                <StackPanel Classes="page-root" Spacing="16">

                        <!--  Password Input Card  -->
                        <Border Classes="card">
                                <StackPanel Classes="field-stack">
                                        <TextBlock Classes="card-title" Text="Password Settings" />

                                        <StackPanel Spacing="4">
                                                <TextBlock Classes="field-label" Text="Enter Password" />
                                                <TextBox
                                                        IsEnabled="{Binding HasStoredPassword, Converter={StaticResource InverseBoolConverter}}"
                                                        PasswordChar="●"
                                                        Text="{Binding Password, Mode=TwoWay}"
                                                        Watermark="Type your password here..." />
                                        </StackPanel>

                                        <TextBlock
                                                Classes="subtle"
                                                Text="Password will be encoded and stored securely in settings" />

                                        <StackPanel Classes="actions">
                                                <Button
                                                        Classes="accent"
                                                        Command="{Binding SavePasswordCommand}"
                                                        IsEnabled="{Binding HasStoredPassword, Converter={StaticResource InverseBoolConverter}}">
                                                        Save Password
                                                </Button>

                                                <Button Command="{Binding ClearPasswordCommand}" IsEnabled="{Binding HasStoredPassword}">
                                                        Clear Stored Password
                                                </Button>
                                        </StackPanel>
                                </StackPanel>
                        </Border>

                        <!--  Status Info Card  -->
                        <Border Classes="card">
                                <StackPanel Spacing="6">
                                        <TextBlock Classes="body-text" Text="Store a password and paste it anywhere using Ctrl+Shift+V" />
                                        <TextBlock
                                                Margin="0,8,0,0"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                                                Text="{Binding StatusMessage, Mode=OneWay}" />
                                </StackPanel>
                        </Border>
                </StackPanel>
        </ScrollViewer>
</UserControl>
