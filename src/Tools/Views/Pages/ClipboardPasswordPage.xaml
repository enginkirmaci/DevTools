<UserControl
        x:Class="Tools.Views.Pages.ClipboardPasswordPage"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:Tools.Library.Converters;assembly=Tools.Library"
        mc:Ignorable="d"
        d:DesignWidth="600" d:DesignHeight="400">

        <UserControl.Resources>
                <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        </UserControl.Resources>

        <ScrollViewer>
                <StackPanel Spacing="24" Margin="16">

                        <!-- Password Input Card -->
                        <Border
                                Padding="24"
                                CornerRadius="8"
                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                                <StackPanel Spacing="16">
                                        <TextBlock
                                                FontWeight="Bold"
                                                FontSize="16"
                                                Text="Password Settings" />

                                        <StackPanel Spacing="4">
                                                <TextBlock
                                                        FontWeight="Medium"
                                                        Text="Enter Password" />
                                                <TextBox
                                                        Watermark="Type your password here..."
                                                        PasswordChar="●"
                                                        Text="{Binding Password, Mode=TwoWay}"
                                                        IsEnabled="{Binding HasStoredPassword, Converter={StaticResource InverseBoolConverter}}" />
                                        </StackPanel>

                                        <TextBlock
                                                Opacity="0.6"
                                                TextWrapping="Wrap"
                                                Text="Password will be encoded and stored securely in settings" />

                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                                <Button
                                                        Command="{Binding SavePasswordCommand}"
                                                        IsEnabled="{Binding HasStoredPassword, Converter={StaticResource InverseBoolConverter}}"
                                                        Classes="accent">
                                                        Save Password
                                                </Button>

                                                <Button
                                                        Command="{Binding ClearPasswordCommand}"
                                                        IsEnabled="{Binding HasStoredPassword}">
                                                        Clear Stored Password
                                                </Button>
                                        </StackPanel>
                                </StackPanel>
                        </Border>

                        <!-- Status Info Card -->
                        <Border
                                Padding="24"
                                CornerRadius="8"
                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                                <StackPanel Spacing="6">
                                        <TextBlock
                                                TextWrapping="Wrap"
                                                Text="Store a password and paste it anywhere using Ctrl+Shift+V" />
                                        <TextBlock
                                                Margin="0,8,0,0"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                                                Text="{Binding StatusMessage, Mode=OneWay}"
                                                TextWrapping="Wrap" />
                                </StackPanel>
                        </Border>
                </StackPanel>
        </ScrollViewer>
</UserControl>
