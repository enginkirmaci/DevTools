<UserControl
        x:Class="Tools.Views.Pages.NugetLocalPage"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tools="using:Tools.Library.MarkupExtensions"
        d:DesignHeight="500"
        d:DesignWidth="700"
        mc:Ignorable="d">

        <Grid
                Classes="page-root"
                RowDefinitions="Auto,Auto,*"
                RowSpacing="12">
                <!--  Top Card: Settings + Operations  -->
                <Border Grid.Row="0"
                        Classes="card">
                        <Grid ColumnDefinitions="*,Auto">
                                <!--  Left: Settings  -->
                                <StackPanel Grid.Column="0"
                                            Classes="field-stack">
                                        <TextBlock
                                                Classes="card-title"
                                                Text="Nuget Package Manager"/>

                                        <StackPanel Spacing="4">
                                                <TextBlock
                                                        Classes="field-label"
                                                        Margin="0,2,0,0"
                                                        Text="Watch Directory"/>
                                                <Grid ColumnDefinitions="*,Auto">
                                                        <TextBox
                                                                Grid.Column="0"
                                                                Margin="0,0,8,0"
                                                                Text="{Binding WatchFolder, Mode=TwoWay}"
                                                                Watermark="Select a folder to watch for .nupkg files..."/>
                                                        <Button
                                                                Grid.Column="1"
                                                                Classes="icon"
                                                                Command="{Binding SelectFolderCommand}"
                                                                CommandParameter="Watch">
                                                                <Path
                                                                        Classes="icon"
                                                                        Data="{tools:SvgPath icon-folder}"/>
                                                        </Button>
                                                </Grid>
                                        </StackPanel>

                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                              RowDefinitions="Auto,Auto">
                                                <TextBlock
                                                        Grid.Column="0"
                                                        Margin="0,0,8,0"
                                                        VerticalAlignment="Center"
                                                        Text="NuGet Local Cache"/>
                                                <TextBlock
                                                        Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Classes="subtle"
                                                        Text="{Binding ComputedCopyFolder}"
                                                        TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Grid.Column="0"
                                                           Grid.Row="1"
                                                           Text="NuGet Global Cache"/>
                                                <TextBlock
                                                        Classes="subtle"
                                                        Grid.Column="1"
                                                        Grid.Row="1"
                                                        Text="{Binding GlobalPackagesFolder}"
                                                        TextTrimming="CharacterEllipsis"/>

                                                <Button
                                                        Grid.Column="2"
                                                        Grid.RowSpan="2"
                                                        Width="100"
                                                        Classes="icon"
                                                        Command="{Binding RegisterSourceCommand}">
                                                        <StackPanel Orientation="Horizontal"
                                                                    Spacing="4">
                                                                <Path
                                                                        Classes="icon"
                                                                        Data="{tools:SvgPath icon-account}"/>
                                                                <TextBlock Text="Register"/>
                                                        </StackPanel>
                                                </Button>
                                        </Grid>
                                </StackPanel>

                                <!--  Right: Operations  -->
                                <StackPanel
                                        Grid.Column="1"
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Top"
                                        Spacing="8">
                                        <TextBlock
                                                HorizontalAlignment="Center"
                                                Classes="field-label"
                                                Text="Operations"/>
                                        <Button
                                                HorizontalAlignment="Center"
                                                Background="{DynamicResource InfoAccentBrush}"
                                                Command="{Binding WatchChangesCommand}"
                                                CommandParameter="{Binding !WatchStarted}"
                                                Foreground="{DynamicResource AccentForegroundBrush}">
                                                <Panel>
                                                        <StackPanel
                                                                Orientation="Horizontal"
                                                                Spacing="4"
                                                                IsVisible="{Binding !WatchStarted}">
                                                                <Path
                                                                        Width="16"
                                                                        Height="16"
                                                                        Data="{tools:SvgPath icon-play}"
                                                                        Fill="{DynamicResource AccentForegroundBrush}"/>
                                                                <TextBlock Text="Start"/>
                                                        </StackPanel>
                                                        <StackPanel
                                                                Orientation="Horizontal"
                                                                Spacing="4"
                                                                IsVisible="{Binding WatchStarted}">
                                                                <Path
                                                                        Width="16"
                                                                        Height="16"
                                                                        Data="{tools:SvgPath icon-stop}"
                                                                        Fill="{DynamicResource AccentForegroundBrush}"/>
                                                                <TextBlock Text="Stop"/>
                                                        </StackPanel>
                                                </Panel>
                                        </Button>
                                </StackPanel>
                        </Grid>
                </Border>

                <!--  Middle Row: Session Activity + How it works  -->
                <Grid
                        Grid.Row="1"
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                        <!--  Session Activity  -->
                        <Border Grid.Column="0"
                                Classes="card">
                                <StackPanel Spacing="8">
                                        <TextBlock Classes="card-title"
                                                   Text="Session Activity"/>
                                        <StackPanel
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal"
                                                Spacing="8">
                                                <Path
                                                        Width="24"
                                                        Height="24"
                                                        Data="{tools:SvgPath icon-chart-bar}"
                                                        Fill="{DynamicResource InfoAccentBrush}"/>
                                                <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="24"
                                                        FontWeight="Bold"
                                                        Text="{Binding Count}"/>
                                        </StackPanel>
                                        <TextBlock Classes="subtle"
                                                   Text="Packages Refreshed"/>
                                </StackPanel>
                        </Border>

                        <!--  How it works  -->
                        <Border Grid.Column="1"
                                Classes="card">
                                <StackPanel Spacing="8">
                                        <TextBlock Classes="card-title"
                                                   Text="How it works"/>
                                        <TextBlock
                                                Classes="body-text"
                                                Text="1. Register your build folder as a local NuGet source."/>
                                        <TextBlock
                                                Classes="body-text"
                                                Text="2. Start Watch to monitor for new build outputs (.nupkg)."/>
                                        <TextBlock
                                                Classes="body-text"
                                                Text="3. On every build, the tool clears the global cache, forcing consumer projects to fetch your fresh DLLs."/>
                                </StackPanel>
                        </Border>
                </Grid>

                <!--  Bottom Card: Activity Log  -->
                <Border Grid.Row="2"
                        Classes="card">
                        <Grid RowDefinitions="Auto,*">
                                <TextBlock
                                        Grid.Row="0"
                                        Classes="card-title"
                                        Margin="0,0,0,8"
                                        Text="Activity Log"/>
                                <ScrollViewer Grid.Row="1">
                                        <ItemsControl ItemsSource="{Binding FileList}">
                                                <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                                <Border
                                                                        Margin="0,1"
                                                                        Padding="4,2"
                                                                        CornerRadius="2">
                                                                        <TextBlock
                                                                                Classes="subtle"
                                                                                Text="{Binding}"/>
                                                                </Border>
                                                        </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                </ScrollViewer>
                        </Grid>
                </Border>
        </Grid>
</UserControl>
