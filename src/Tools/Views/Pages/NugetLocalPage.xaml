<UserControl
        x:Class="Tools.Views.Pages.NugetLocalPage"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DesignHeight="500"
        d:DesignWidth="700"
        mc:Ignorable="d">

        <Grid
                Margin="16"
                RowDefinitions="Auto,Auto,*"
                RowSpacing="12">
                <!--  Top Card: Settings + Operations  -->
                <Border
                        Grid.Row="0"
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                        CornerRadius="8">
                        <Grid ColumnDefinitions="*,Auto">
                                <!--  Left: Settings  -->
                                <StackPanel Grid.Column="0" Spacing="12">
                                        <TextBlock
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Text="Nuget Package Manager" />

                                        <StackPanel Spacing="4">
                                                <TextBlock Opacity="0.7" Text="Watch Directory" />
                                                <Grid ColumnDefinitions="*,Auto">
                                                        <TextBox
                                                                Grid.Column="0"
                                                                Margin="0,0,8,0"
                                                                Text="{Binding WatchFolder, Mode=TwoWay}"
                                                                Watermark="Select a folder to watch for .nupkg files..." />
                                                        <Button
                                                                Grid.Column="1"
                                                                Padding="8,4"
                                                                Command="{Binding SelectFolderCommand}"
                                                                CommandParameter="Watch">
                                                                <Path
                                                                        Width="16"
                                                                        Height="16"
                                                                        Data="M20,18H4V8H20M20,6H12L10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6Z"
                                                                        Fill="#A0A0A0" />
                                                        </Button>
                                                </Grid>
                                        </StackPanel>

                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                                <TextBlock
                                                        Grid.Column="0"
                                                        Margin="0,0,8,0"
                                                        VerticalAlignment="Center"
                                                        Text="NuGet Local Cache" />
                                                <TextBlock
                                                        Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Opacity="0.6"
                                                        Text="{Binding ComputedCopyFolder}" />
                                                <Button
                                                        Grid.Column="2"
                                                        Padding="8,4"
                                                        Command="{Binding RegisterSourceCommand}">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <Path
                                                                        Width="16"
                                                                        Height="16"
                                                                        Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                                                                        Fill="#A0A0A0" />
                                                                <TextBlock Text="Register" />
                                                        </StackPanel>
                                                </Button>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="NuGet Global Cache" />
                                                <TextBlock Opacity="0.6" Text="{Binding GlobalPackagesFolder}" />
                                        </StackPanel>
                                </StackPanel>

                                <!--  Right: Operations  -->
                                <StackPanel
                                        Grid.Column="1"
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Top"
                                        Spacing="8">
                                        <TextBlock
                                                HorizontalAlignment="Center"
                                                Opacity="0.7"
                                                Text="Operations" />
                                        <Button
                                                HorizontalAlignment="Center"
                                                Background="#2196F3"
                                                Command="{Binding WatchChangesCommand}"
                                                CommandParameter="{Binding !WatchStarted}"
                                                Foreground="White">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <Path
                                                                Width="16"
                                                                Height="16"
                                                                Data="M8,5.14V19.14L19,12.14L8,5.14Z"
                                                                Fill="White" />
                                                        <TextBlock Text="{Binding WatchStarted, Converter={x:Static BoolConverters.Not}}" />
                                                </StackPanel>
                                        </Button>
                                </StackPanel>
                        </Grid>
                </Border>

                <!--  Middle Row: Session Activity + How it works  -->
                <Grid
                        Grid.Row="1"
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                        <!--  Session Activity  -->
                        <Border
                                Grid.Column="0"
                                Padding="16"
                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="8">
                                <StackPanel Spacing="8">
                                        <TextBlock
                                                FontSize="14"
                                                FontWeight="Bold"
                                                Text="Session Activity" />
                                        <StackPanel
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal"
                                                Spacing="8">
                                                <Path
                                                        Width="24"
                                                        Height="24"
                                                        Data="M22,21H2V3H4V19H6V10H10V19H12V6H16V19H18V14H22V21Z"
                                                        Fill="#2196F3" />
                                                <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="24"
                                                        FontWeight="Bold"
                                                        Text="{Binding Count}" />
                                        </StackPanel>
                                        <TextBlock Opacity="0.6" Text="Packages Refreshed" />
                                </StackPanel>
                        </Border>

                        <!--  How it works  -->
                        <Border
                                Grid.Column="1"
                                Padding="16"
                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="8">
                                <StackPanel Spacing="8">
                                        <TextBlock
                                                FontSize="14"
                                                FontWeight="Bold"
                                                Text="How it works" />
                                        <TextBlock
                                                Opacity="0.8"
                                                Text="1. Register your build folder as a local NuGet source."
                                                TextWrapping="Wrap" />
                                        <TextBlock
                                                Opacity="0.8"
                                                Text="2. Start Watch to monitor for new build outputs (.nupkg)."
                                                TextWrapping="Wrap" />
                                        <TextBlock
                                                Opacity="0.8"
                                                Text="3. On every build, the tool clears the global cache, forcing consumer projects to fetch your fresh DLLs."
                                                TextWrapping="Wrap" />
                                </StackPanel>
                        </Border>
                </Grid>

                <!--  Bottom Card: Activity Log  -->
                <Border
                        Grid.Row="2"
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                        CornerRadius="8">
                        <Grid RowDefinitions="Auto,*">
                                <TextBlock
                                        Grid.Row="0"
                                        Margin="0,0,0,8"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Text="Activity Log" />
                                <ScrollViewer Grid.Row="1">
                                        <ItemsControl ItemsSource="{Binding FileList}">
                                                <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                                <Border
                                                                        Margin="0,1"
                                                                        Padding="4,2"
                                                                        CornerRadius="2">
                                                                        <TextBlock
                                                                                FontSize="12"
                                                                                Opacity="0.8"
                                                                                Text="{Binding}" />
                                                                </Border>
                                                        </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                </ScrollViewer>
                        </Grid>
                </Border>
        </Grid>
</UserControl>
