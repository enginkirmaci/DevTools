<UserControl
        x:Class="Tools.Views.Pages.HostFileProxyPage"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="600" d:DesignHeight="400">

        <StackPanel Classes="page-root" Spacing="16">
                <Border Classes="card">
                        <StackPanel Spacing="12">
                                <TextBlock Classes="card-title" Text="Host File Proxy" />
                                <TextBlock
                                        Classes="body-text"
                                        Text="Host File Proxy service manages local hosts file entries for development environments." />
                                <TextBlock
                                        Classes="subtle"
                                        Text="This functionality is currently being migrated to Avalonia." />
                        </StackPanel>
                </Border>
        </StackPanel>
</UserControl>
