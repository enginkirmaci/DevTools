<UserControl
        x:Class="Tools.Views.Pages.FormattersPage"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Name="RootPage"
        d:DesignHeight="700"
        d:DesignWidth="900"
        mc:Ignorable="d">

        <Grid Classes="page-root" RowDefinitions="Auto,*">
                <TextBlock
                        Grid.Row="0"
                        Classes="section-title"
                        Text="Formatters" />

                <Grid Grid.Row="1" ColumnDefinitions="260,*">
                        <!--  Operation Selection  -->
                        <Border
                                Grid.Column="0"
                                Classes="card"
                                Margin="0,0,12,0"
                                VerticalAlignment="Top">
                                <StackPanel Spacing="4">
                                        <TextBlock
                                                Classes="card-title"
                                                Margin="0,0,0,8"
                                                Text="Convert to" />
                                        <RadioButton
                                                Content="Base64 Encode"
                                                GroupName="Operation"
                                                IsChecked="{Binding IsBase64EncodeSelected, Mode=TwoWay}" />
                                        <RadioButton
                                                Content="Base64 Decode"
                                                GroupName="Operation"
                                                IsChecked="{Binding IsBase64DecodeSelected, Mode=TwoWay}" />
                                        <RadioButton
                                                Content="Snake Case"
                                                GroupName="Operation"
                                                IsChecked="{Binding IsSnakeCaseSelected, Mode=TwoWay}" />
                                        <RadioButton
                                                Content="Pascal Case"
                                                GroupName="Operation"
                                                IsChecked="{Binding IsPascalCaseSelected, Mode=TwoWay}" />
                                </StackPanel>
                        </Border>

                        <!--  Input and Output Area  -->
                        <Grid Grid.Column="1" RowDefinitions="Auto,*">
                                <!--  Input Area  -->
                                <Border
                                        Grid.Row="0"
                                        Classes="card"
                                        Margin="0,0,0,12">
                                        <Grid ColumnDefinitions="*,Auto">
                                                <TextBox
                                                        Grid.Column="0"
                                                        Margin="0,0,8,0"
                                                        VerticalAlignment="Center"
                                                        AcceptsReturn="True"
                                                        Text="{Binding InputText, Mode=TwoWay}"
                                                        TextWrapping="Wrap"
                                                        Watermark="Enter text to convert..." />
                                                <Button
                                                        Grid.Column="1"
                                                        Height="36"
                                                        VerticalAlignment="Center"
                                                        Classes="accent"
                                                        Command="{Binding ConvertCommand}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <TextBlock FontSize="14" Text="▶" />
                                                                <TextBlock Text="Convert" />
                                                        </StackPanel>
                                                </Button>
                                        </Grid>
                                </Border>

                                <!--  Output Area  -->
                                <Border
                                        Grid.Row="1"
                                        Classes="card">
                                        <Grid RowDefinitions="Auto,*">
                                                <TextBlock
                                                        Grid.Row="0"
                                                        Classes="card-title"
                                                        Margin="0,0,0,6"
                                                        Text="Output" />
                                                <ScrollViewer Grid.Row="1">
                                                        <TextBlock Classes="body-text" Text="{Binding OutputText, Mode=OneWay}" />
                                                </ScrollViewer>
                                        </Grid>
                                </Border>
                        </Grid>
                </Grid>
        </Grid>
</UserControl>
