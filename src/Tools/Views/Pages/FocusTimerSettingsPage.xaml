<UserControl
	x:Class="Tools.Views.Pages.FocusTimerSettingsPage"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	d:DesignWidth="700" d:DesignHeight="500">

	<Grid Classes="page-root" RowDefinitions="Auto,Auto,*,Auto">

		<TextBlock
			Grid.Row="0"
			Classes="section-title"
			Text="Focus Timer Settings" />

		<Border
			Grid.Row="1"
			Classes="card"
			Margin="0,0,0,12">
			<StackPanel Classes="field-stack">
				<TextBlock Classes="card-title" Text="Focus Timer" />
				<TextBlock Classes="body-text" Text="{Binding TimerStatusText}" />
				<StackPanel Orientation="Horizontal" Spacing="12">
					<TextBlock Text="Break Pool:" FontWeight="Medium" />
					<TextBlock Text="{Binding CurrentBreakPoolText}" />
					<TextBlock
						Margin="12,0,0,0"
						FontWeight="Medium"
						Text="Breaks Today:" />
					<TextBlock Text="{Binding BreaksTakenTodayText}" />
				</StackPanel>
				<StackPanel Classes="actions">
					<Button Classes="accent" Command="{Binding StartTimerCommand}" Content="Start" />
					<Button Command="{Binding StopTimerCommand}" Content="Stop" />
					<Button Command="{Binding ResetDailyStateCommand}" Content="Reset Daily" />
				</StackPanel>
			</StackPanel>
		</Border>

		<ScrollViewer Grid.Row="2">
			<StackPanel Spacing="12">
				<Border Classes="card">
					<StackPanel Classes="field-stack">
						<TextBlock Classes="card-title" Text="Work Window" />
						<StackPanel Orientation="Horizontal" Spacing="12">
							<StackPanel Spacing="4">
								<TextBlock Classes="field-label" Text="Start Time" />
								<TextBox
									Width="100"
									Text="{Binding WorkStartTime, Mode=TwoWay}" />
							</StackPanel>
							<StackPanel Spacing="4">
								<TextBlock Classes="field-label" Text="End Time" />
								<TextBox
									Width="100"
									Text="{Binding WorkEndTime, Mode=TwoWay}" />
							</StackPanel>
						</StackPanel>
					</StackPanel>
				</Border>

				<Border Classes="card">
					<StackPanel Classes="field-stack">
						<TextBlock Classes="card-title" Text="Break Goals" />
						<StackPanel Orientation="Horizontal" Spacing="12">
							<StackPanel Spacing="4">
								<TextBlock Classes="field-label" Text="Daily Minutes" />
								<TextBox
									Width="80"
									Text="{Binding TotalDailyBreakMinutes, Mode=TwoWay}" />
							</StackPanel>
							<StackPanel Spacing="4">
								<TextBlock Classes="field-label" Text="Break Count" />
								<TextBox
									Width="80"
									Text="{Binding DesiredBreakCount, Mode=TwoWay}" />
							</StackPanel>
						</StackPanel>
						<StackPanel
							Margin="0,4,0,0"
							Orientation="Horizontal"
							Spacing="12">
							<TextBlock Text="Duration:" />
							<TextBlock Text="{Binding CalculatedBreakDuration}" />
							<TextBlock Margin="12,0,0,0" Text="Interval:" />
							<TextBlock Text="{Binding CalculatedBreakInterval}" />
						</StackPanel>
					</StackPanel>
				</Border>

				<Border Classes="card">
					<StackPanel Classes="field-stack">
						<TextBlock Classes="card-title" Text="Display" />
						<ComboBox
							ItemsSource="{Binding VisibilityModes}"
							SelectedIndex="{Binding SelectedVisibilityMode}" />
						<ComboBox
							ItemsSource="{Binding CornerPositions}"
							SelectedIndex="{Binding SelectedCornerPosition}" />
						<CheckBox Content="Play sound on notification" IsChecked="{Binding PlaySoundOnNotification}" />
					</StackPanel>
				</Border>
			</StackPanel>
		</ScrollViewer>

		<Border
			Grid.Row="3"
			Padding="12"
			Margin="0,12,0,0">
			<Button
				HorizontalAlignment="Center"
				Classes="accent"
				Command="{Binding ShowTimerWindowCommand}"
				Content="Show Timer Window" />
		</Border>
	</Grid>
</UserControl>
