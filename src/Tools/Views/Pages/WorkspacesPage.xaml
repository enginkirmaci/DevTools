<UserControl
        x:Class="Tools.Views.Pages.WorkspacesPage"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="800" d:DesignHeight="500">

        <Grid RowDefinitions="Auto,*" Margin="16">
                <!-- Search and Filter -->
                <Border Grid.Row="0" Padding="16" Margin="0,0,0,12" CornerRadius="8"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                        <StackPanel Spacing="8">
                                <TextBlock FontWeight="Bold" FontSize="16" Text="Workspaces" />
                                <TextBox Watermark="Filter workspaces..."
                                         Text="{Binding FilterText, Mode=TwoWay}" />
                        </StackPanel>
                </Border>

                <!-- Results -->
                <ScrollViewer Grid.Row="1">
                        <StackPanel Spacing="12">
                                <TextBlock Text="Solutions" FontWeight="Bold" FontSize="14" />
                                <ItemsControl ItemsSource="{Binding FilteredWorkspaces}">
                                        <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                        <Border Padding="12,8" Margin="0,2" CornerRadius="4"
                                                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                                                                <Grid ColumnDefinitions="*,Auto">
                                                                        <StackPanel Grid.Column="0" Spacing="2">
                                                                                <TextBlock Text="{Binding SolutionName}" FontWeight="Medium" />
                                                                                <TextBlock Text="{Binding FolderPath}" FontSize="12" Opacity="0.6" />
                                                                        </StackPanel>
                                                                </Grid>
                                                        </Border>
                                                </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Platforms" FontWeight="Bold" FontSize="14" Margin="0,8,0,0" />
                                <ItemsControl ItemsSource="{Binding FilteredPlatforms}">
                                        <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                        <Border Padding="12,8" Margin="0,2" CornerRadius="4"
                                                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                                                                <Grid ColumnDefinitions="*,Auto">
                                                                        <StackPanel Grid.Column="0" Spacing="2">
                                                                                <TextBlock Text="{Binding PlatformName}" FontWeight="Medium" />
                                                                                <TextBlock Text="{Binding FolderPath}" FontSize="12" Opacity="0.6" />
                                                                        </StackPanel>
                                                                </Grid>
                                                        </Border>
                                                </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                </ItemsControl>
                        </StackPanel>
                </ScrollViewer>
        </Grid>
</UserControl>
