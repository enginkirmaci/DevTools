<UserControl
        x:Class="Tools.Views.Pages.WorkspacesPage"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Name="Root"
        d:DesignHeight="500"
        d:DesignWidth="800"
        mc:Ignorable="d">

        <Grid Margin="16" RowDefinitions="Auto,Auto,*">

                <!--  Workspaces Title  -->
                <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        FontSize="16"
                        FontWeight="Bold"
                        Text="Workspaces" />

                <!--  Search and Filter  -->
                <Border
                        Grid.Row="1"
                        Margin="0,0,0,16"
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                        CornerRadius="8">
                        <Grid ColumnDefinitions="*,Auto,1,Auto" ColumnSpacing="8">
                                <TextBox
                                        Grid.Column="0"
                                        Text="{Binding FilterText, Mode=TwoWay}"
                                        Watermark="Filter..." />
                                <Button
                                        Grid.Column="1"
                                        Padding="8,4"
                                        Command="{Binding RefreshCommand}"
                                        IsEnabled="{Binding !IsBusy}">
                                        <Path
                                                Width="16"
                                                Height="16"
                                                Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                                Fill="#A0A0A0" />
                                </Button>
                                <Border
                                        Grid.Column="2"
                                        Width="1"
                                        Margin="0,2"
                                        Background="#3F3F46" />
                                <Button
                                        Grid.Column="3"
                                        Padding="8,4"
                                        Command="{Binding OpenSettingsCommand}">
                                        <Path
                                                Width="16"
                                                Height="16"
                                                Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                                Fill="#A0A0A0" />
                                </Button>
                        </Grid>
                </Border>

                <!--  Results  -->
                <ScrollViewer Grid.Row="2">
                        <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="2">
                                        <TextBlock
                                                FontSize="14"
                                                FontWeight="Bold"
                                                Text="Projects" />
                                        <TextBlock
                                                VerticalAlignment="Center"
                                                Opacity="0.6"
                                                Text="(" />
                                        <TextBlock
                                                VerticalAlignment="Center"
                                                Opacity="0.6"
                                                Text="{Binding FilteredWorkspaces.Count}" />
                                        <TextBlock
                                                VerticalAlignment="Center"
                                                Opacity="0.6"
                                                Text=" )" />
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding FilteredWorkspaces}">
                                        <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                        <UniformGrid Columns="2" />
                                                </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                        <Border
                                                                Margin="0,0,16,8"
                                                                Padding="12,10"
                                                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                                                CornerRadius="4">
                                                                <Grid ColumnDefinitions="*,Auto">
                                                                        <StackPanel
                                                                                Grid.Column="0"
                                                                                VerticalAlignment="Center"
                                                                                Spacing="2">
                                                                                <TextBlock FontWeight="Medium" Text="{Binding SolutionName}" />
                                                                                <TextBlock
                                                                                        FontSize="12"
                                                                                        Opacity="0.6"
                                                                                        Text="{Binding FolderPath}" />
                                                                        </StackPanel>
                                                                        <Grid
                                                                                Grid.Column="1"
                                                                                Margin="8,0,0,0"
                                                                                VerticalAlignment="Center"
                                                                                ColumnDefinitions="Auto,1,Auto">
                                                                                <Button
                                                                                        Grid.Column="0"
                                                                                        Padding="6,4"
                                                                                        Background="Transparent"
                                                                                        BorderThickness="0"
                                                                                        Command="{Binding #Root.DataContext.OpenSolutionCommand}"
                                                                                        CommandParameter="{Binding SolutionPath}">
                                                                                        <Path
                                                                                                Width="18"
                                                                                                Height="18"
                                                                                                Data="M19.5,3h-15C3.67,3 3,3.67 3,4.5v15c0,0.83 0.67,1.5 1.5,1.5h15c0.83,0 1.5,-0.67 1.5,-1.5v-15C21,3.67 20.33,3 19.5,3zM14.5,8L12,10.5L9.5,8L8,9.5L10.5,12L8,14.5L9.5,16L12,13.5L14.5,16L16,14.5L13.5,12L16,9.5L14.5,8z"
                                                                                                Fill="#8B5CF6" />
                                                                                </Button>
                                                                                <Border
                                                                                        Grid.Column="1"
                                                                                        Width="1"
                                                                                        Margin="4,2"
                                                                                        Background="#3F3F46" />
                                                                                <Button
                                                                                        Grid.Column="2"
                                                                                        Padding="6,4"
                                                                                        Background="Transparent"
                                                                                        BorderThickness="0">
                                                                                        <Path
                                                                                                Width="12"
                                                                                                Height="12"
                                                                                                Data="M7,10L12,15L17,10H7Z"
                                                                                                Fill="#A0A0A0" />
                                                                                        <Button.Flyout>
                                                                                                <MenuFlyout>
                                                                                                        <MenuItem
                                                                                                                Command="{Binding #Root.DataContext.OpenWithVSCodeCommand}"
                                                                                                                CommandParameter="{Binding FolderPath}"
                                                                                                                Header="Open with VS Code:">
                                                                                                                <MenuItem.Icon>
                                                                                                                        <Path
                                                                                                                                Width="16"
                                                                                                                                Height="16"
                                                                                                                                Data="M23,1L14,9L10,5L1,14L5,18L14,9L18,13L23,1Z"
                                                                                                                                Fill="#007ACC" />
                                                                                                                </MenuItem.Icon>
                                                                                                        </MenuItem>
                                                                                                        <MenuItem
                                                                                                                Command="{Binding #Root.DataContext.OpenWithTerminalCommand}"
                                                                                                                CommandParameter="{Binding FolderPath}"
                                                                                                                Header="Open in Terminal">
                                                                                                                <MenuItem.Icon>
                                                                                                                        <Path
                                                                                                                                Width="16"
                                                                                                                                Height="16"
                                                                                                                                Data="M2,3H22V21H2V3M4,5V19H20V5H4M6,7H18V9H6V7M6,11H12V13H6V11M6,15H16V17H6V15Z"
                                                                                                                                Fill="#A0A0A0" />
                                                                                                                </MenuItem.Icon>
                                                                                                        </MenuItem>
                                                                                                        <MenuItem
                                                                                                                Command="{Binding #Root.DataContext.OpenFolderCommand}"
                                                                                                                CommandParameter="{Binding FolderPath}"
                                                                                                                Header="Show in Explorer">
                                                                                                                <MenuItem.Icon>
                                                                                                                        <Path
                                                                                                                                Width="16"
                                                                                                                                Height="16"
                                                                                                                                Data="M20,18H4V8H20M20,6H12L10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6Z"
                                                                                                                                Fill="#FFB900" />
                                                                                                                </MenuItem.Icon>
                                                                                                        </MenuItem>
                                                                                                </MenuFlyout>
                                                                                        </Button.Flyout>
                                                                                </Button>
                                                                        </Grid>
                                                                </Grid>
                                                        </Border>
                                                </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                </ItemsControl>
                        </StackPanel>
                </ScrollViewer>
        </Grid>
</UserControl>
