<?xml version="1.0" encoding="utf-8" ?>
<Window
	x:Class="Tools.Views.Windows.MainWindow"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:tools="using:Tools.Library.MarkupExtensions"
	Title=""
	Width="1200"
	Height="800"
	MinWidth="800"
	MinHeight="600"
	ExtendClientAreaToDecorationsHint="True">

	<Grid ColumnDefinitions="240,*" RowDefinitions="38,*">
		<!--  Custom Title Bar  -->
		<Border
			Grid.Row="0"
			Grid.ColumnSpan="2"
			Background="{DynamicResource SidebarBackgroundBrush}"
			BorderBrush="{DynamicResource SidebarBorderBrush}"
			BorderThickness="0,0,0,1"
			IsHitTestVisible="True"
			PointerPressed="TitleBar_PointerPressed">
			<DockPanel Margin="14,0" VerticalAlignment="Center">
				<!--  Hamburger Menu  -->
				<Path
					Width="18"
					Height="18"
					Margin="0,0,10,0"
					Data="{tools:SvgPath icon-menu}"
					DockPanel.Dock="Left"
					Fill="{DynamicResource SubtitleForegroundBrush}"
					Stretch="Uniform" />
				<TextBlock
					VerticalAlignment="Center"
					DockPanel.Dock="Left"
					FontSize="13"
					FontWeight="SemiBold"
					Foreground="{DynamicResource SubtitleForegroundBrush}"
					Text="DevTools" />
				<Button
					x:Name="BackButton"
					Margin="16,0,0,0"
					Click="BackButton_Click"
					Content="←"
					DockPanel.Dock="Left"
					IsVisible="False" />
			</DockPanel>
		</Border>

		<!--  Sidebar Navigation  -->
		<Border
			Grid.Row="1"
			Grid.Column="0"
			Padding="0,8,0,0"
			Background="{DynamicResource SidebarBackgroundBrush}"
			BorderBrush="{DynamicResource SidebarBorderBrush}"
			BorderThickness="0,0,1,0">
			<ListBox
				x:Name="NavigationListBox"
				Padding="8,0"
				Background="Transparent"
				BorderThickness="0"
				ItemsSource="{Binding MenuItems}"
				SelectedIndex="0"
				SelectionChanged="NavigationListBox_SelectionChanged">
				<ListBox.Styles>
					<Style Selector="ListBoxItem">
						<Setter Property="Padding" Value="0" />
						<Setter Property="Background" Value="Transparent" />
					</Style>
					<Style Selector="ListBoxItem:selected">
						<Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}" />
					</Style>
					<Style Selector="ListBoxItem:pointerover">
						<Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
					</Style>
				</ListBox.Styles>
				<ListBox.ItemTemplate>
					<DataTemplate>
						<Panel>
							<!--  Separator line  -->
							<Border
								Height="1"
								Margin="16,8"
								Background="{DynamicResource DividerBrush}"
								IsVisible="{Binding PageKey, Converter={StaticResource EqualVisibilityConverter}, ConverterParameter=__separator__}" />
							<!--  Section header  -->
							<TextBlock
								Margin="16,12,0,4"
								FontSize="11"
								FontWeight="SemiBold"
								Foreground="{DynamicResource FaintForegroundBrush}"
								IsVisible="{Binding PageKey, Converter={StaticResource EqualVisibilityConverter}, ConverterParameter=__header__}"
								Text="{Binding Title}" />
							<!--  Normal navigation item  -->
							<Border
								Margin="0,1"
								Padding="12,8"
								Background="Transparent"
								CornerRadius="6"
								IsVisible="{Binding PageKey, Converter={StaticResource EqualNotVisibilityConverter}, ConverterParameter=__separator__}">
								<StackPanel Orientation="Horizontal" Spacing="12">
									<Path
										Width="18"
										Height="18"
										VerticalAlignment="Center"
										Data="{Binding IconPath, Converter={StaticResource StringToGeometryConverter}}"
										Fill="{DynamicResource MutedForegroundBrush}"
										Stretch="Uniform" />
									<TextBlock
										VerticalAlignment="Center"
										FontSize="13"
										Foreground="{DynamicResource BodyForegroundBrush}"
										Text="{Binding Title}" />
								</StackPanel>
							</Border>
						</Panel>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>
		</Border>

		<!--  Content Area  -->
		<Grid
			Grid.Row="1"
			Grid.Column="1"
			Background="{DynamicResource ContentBackgroundBrush}">
			<Grid.RowDefinitions>
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<ContentControl
				x:Name="ContentArea"
				Grid.Row="0"
				Padding="0"
				Content="{Binding CurrentView}" />

			<!--  Info Bar  -->
			<!--  InfoBar removed during migration  -->
		</Grid>
	</Grid>
</Window>
