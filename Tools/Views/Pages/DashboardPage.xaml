<?xml version="1.0" encoding="utf-8" ?>
<Page
	x:Class="Tools.Views.Pages.DashboardPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Background="Transparent"
	mc:Ignorable="d">

	<Grid Padding="-32,-24">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!--  Modern Header Banner with Gradient  -->
		<Border
			Grid.Row="0"
			MinHeight="160"
			Margin="0,36,0,0"
			Padding="28,24,28,20">
			<Border.Background>
				<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
					<GradientStop Offset="0" Color="{StaticResource LayerOnMicaBaseAltFillColorSecondary}" />
					<GradientStop Offset="0.5" Color="{StaticResource LayerOnMicaBaseAltFillColorSecondary}" />
					<GradientStop Offset="1" Color="Transparent" />
				</LinearGradientBrush>
			</Border.Background>
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<StackPanel
					Grid.Column="0"
					VerticalAlignment="Center"
					Spacing="6">
					<TextBlock
						Foreground="White"
						Style="{StaticResource TitleTextBlockStyle}"
						Text="Development Tools" />
					<TextBlock
						Foreground="White"
						Opacity="0.7"
						Style="{StaticResource CaptionTextBlockStyle}"
						Text="Quick access to your development utilities" />

					<Border
						Margin="0,12,0,0"
						Padding="12,8"
						HorizontalAlignment="Left"
						Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
						BorderThickness="1"
						CornerRadius="6">
						<StackPanel Orientation="Horizontal" Spacing="8">
							<Border
								Width="8"
								Height="8"
								VerticalAlignment="Center"
								CornerRadius="4">
								<Border.Background>
									<SolidColorBrush Color="{x:Bind ViewModel.SnapItRunning, Mode=OneWay, Converter={StaticResource BoolToColorConverter}}" />
								</Border.Background>
							</Border>
							<TextBlock
								VerticalAlignment="Center"
								Foreground="{ThemeResource TextFillColorPrimaryBrush}"
								Style="{StaticResource CaptionTextBlockStyle}"
								Text="SnapIt" />
							<Border
								Width="1"
								Height="12"
								VerticalAlignment="Center"
								Background="{ThemeResource CardStrokeColorDefaultBrush}" />
							<TextBlock
								VerticalAlignment="Center"
								Foreground="{ThemeResource TextFillColorSecondaryBrush}"
								Style="{StaticResource CaptionTextBlockStyle}"
								Text="{x:Bind ViewModel.SnapItStatusText, Mode=OneWay}" />
						</StackPanel>
					</Border>
				</StackPanel>
				<FontIcon
					Grid.Column="1"
					Margin="16,0,0,0"
					FontSize="64"
					Foreground="White"
					Glyph="&#xE8F1;"
					Opacity="0.4" />
			</Grid>
		</Border>

		<!--  Dashboard Cards  -->
		<ScrollViewer
			Grid.Row="1"
			Padding="24,0,24,12"
			HorizontalScrollMode="Disabled"
			VerticalScrollBarVisibility="Auto">
			<ItemsRepeater ItemsSource="{x:Bind ViewModel.DashboardCards}">
				<ItemsRepeater.Layout>
					<UniformGridLayout
						ItemsStretch="Fill"
						MinColumnSpacing="12"
						MinItemHeight="96"
						MinItemWidth="280"
						MinRowSpacing="12" />
				</ItemsRepeater.Layout>
				<ItemsRepeater.ItemTemplate>
					<DataTemplate>
						<Button
							Padding="0"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Stretch"
							HorizontalContentAlignment="Stretch"
							Command="{Binding Command}"
							CommandParameter="{Binding PageKey}"
							CornerRadius="8">
							<Grid Padding="20,16" ColumnSpacing="16">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto" />
									<ColumnDefinition Width="*" />
								</Grid.ColumnDefinitions>

								<FontIcon
									Grid.Column="0"
									Width="40"
									Height="40"
									FontSize="24"
									Foreground="{ThemeResource TextFillColorPrimaryBrush}"
									Glyph="{Binding Symbol}" />

								<StackPanel
									Grid.Column="1"
									VerticalAlignment="Center"
									Spacing="2">
									<TextBlock
										FontWeight="SemiBold"
										Foreground="{ThemeResource TextFillColorPrimaryBrush}"
										Text="{Binding Title}"
										TextWrapping="Wrap" />
									<TextBlock
										Foreground="{ThemeResource TextFillColorSecondaryBrush}"
										Style="{StaticResource CaptionTextBlockStyle}"
										Text="{Binding Subtitle}"
										TextWrapping="Wrap"
										Visibility="{Binding Subtitle, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}" />
								</StackPanel>
							</Grid>
						</Button>
					</DataTemplate>
				</ItemsRepeater.ItemTemplate>
			</ItemsRepeater>
		</ScrollViewer>
	</Grid>
</Page>
